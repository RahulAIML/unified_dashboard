# ─────────────────────────────────────────────────────────────────────────────
#  Rolplay Analytics Dashboard — Environment Variables
#
#  Copy this file to .env.local and fill in every value before running.
#  .env.local is git-ignored and MUST never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth Database (PostgreSQL) ────────────────────────────────────────────────
# Stores users, sessions, and branding settings.
# Recommended providers: Neon (neon.tech), Supabase, Railway, Render Postgres
#
AUTH_DATABASE_URL=postgresql://user:password@host:5432/rolplay_auth_db

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Access tokens expire in 8 hours. Refresh tokens expire in 7 days.
#
JWT_SECRET=replace_with_random_64_char_hex_string
REFRESH_SECRET=replace_with_different_random_64_char_hex_string

# ── PHP Bridge (Analytics MySQL) ──────────────────────────────────────────────
# The PHP bridge proxies all MySQL queries from Next.js → coach_app / rolplay_pro_analytics.
# BRIDGE_URL points to your deployed bridge endpoint.
# BRIDGE_SECRET is the shared key sent in the X-Bridge-Key header.
#
BRIDGE_URL=https://your-bridge.example.com/bridge.php
BRIDGE_SECRET=your_bridge_secret_key

# ── Direct MySQL Fallback (used only when BRIDGE_URL is not set) ──────────────
# Leave blank if using the PHP bridge above.
#
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=rolplay_pro_analytics

# ── Bridge Timeouts (optional, defaults shown) ────────────────────────────────
# DB_BRIDGE_TIMEOUT_MS=12000
# DB_QUERY_TIMEOUT_MS=12000

# ── Second Brain API ──────────────────────────────────────────────────────────
# External hosted API for the Second Brain module (WhatsApp AI coaching).
# Leave blank to disable the Second Brain tab entirely.
#
SECOND_BRAIN_API_URL=https://your-second-brain-api.example.com
SECOND_BRAIN_API_TOKEN=your_second_brain_api_token
SECOND_BRAIN_ADMIN_EMAIL=admin@yourcompany.com

# ── Organisation Detection ────────────────────────────────────────────────────
# Comma-separated email domains that belong to the Banco pipeline.
# Leave blank if you don't have Banco users.
#
# BANCO_EMAIL_DOMAINS=bancoppel.com,coppel.com

# ── One-time Setup ────────────────────────────────────────────────────────────
# Secret for GET /api/auth/setup (creates DB schema).
# Only needed once. Remove after first run.
#
SETUP_SECRET=replace_with_random_secret

# ── Demo Mode (presentation only) ────────────────────────────────────────────
# Set to 'true' ONLY for live demos when the real DB is unavailable.
# All API routes return high-quality synthetic data when enabled.
# MUST be 'false' in production.
#
NEXT_PUBLIC_DEMO_MODE=false
